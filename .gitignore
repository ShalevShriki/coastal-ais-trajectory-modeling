# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.eggs/
dist/
build/

# Data files (raw processed data stays out of git)
data/*
!data/results/
!data/results/**
data/results/**/*.log
*.csv
*.parquet
*.json
!data/results/**/*.json
*.pkl
*.npy
*.npz
*.h5
*.hdf5

# Model checkpoints: track under data/models/ as experiment anchors;
# ignore loose *.pt elsewhere in the tree.
*.pt
*.pth
*.ckpt
!data/models/
!data/models/**/
!data/models/**/*.pt
!data/models/**/*.pth
!data/models/**/*.ckpt

# Logs and outputs
*.out
*.log
LOG/
slurm_logs/

# Local archive: keep scripts/docs in git; skip heavy dumps on disk
old_versions/data_processed/
old_versions/data_models/
old_versions/data_results/
old_versions/logs/

# System
.DS_Store
.env
